#!/system/bin/sh
# update-binary  —  听闻人间十三月
# "远处烟雨下的漓江每次都是匆匆而过"
#─────────────────────────────────────────────

SKIPUNZIP=1

# KSU 会自动执行 customize.sh，不需要在这里 source
# Magisk / APatch 兼容：手动 source customize.sh
# 通过 KSU 变量判断当前环境
if [ "${KSU:-false}" != "true" ]; then
    [ -f "$MODPATH/customize.sh" ] || unzip -o "$ZIPFILE" customize.sh -d "$MODPATH" >&2
    . "$MODPATH/customize.sh"
fi
